{% stylesheet %}
  .topbar-inner {
    padding: 8px 0;
    color: white;
  }
{% endstylesheet %}

<style>
  .topbar {
      background-color: {{section.settings.bg_color}};
  }
</style>

<div class="topbar-inner section section--page-width color-{{ section.settings.color_scheme }}">
  <div class="flex">
    <div>{{ section.settings.left_text }}</div>

    <div class="flex">
      <a href="tel:{{ section.settings.phone_link }}" class="flex">
        <span class="icon"> {% render 'icon', icon: 'phone' %} </span> {{ section.settings.phone -}}
      </a>
      <a href="mailto:{{ section.settings.email }}" class="flex">
        <span class="icon"> {% render 'icon', icon: 'email' %} </span>
        {{ section.settings.email }}
      </a>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Topbar",
  "class": "topbar",
  "enabled_on": {
    "groups": ["header"]
  },
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color"
    },
    {
      "type": "text",
      "id": "left_text",
      "label": "Left Text"
    },
    {
      "type": "text",
      "id": "email",
      "label": "Email"
    },
    {
      "type": "text",
      "id": "phone",
      "label": "Phone Text"
    },
    {
      "type": "text",
      "id": "phone_link",
      "label": "Phone Link"
    },
    {
      "type": "checkbox",
      "id": "show_currency",
      "label": "Currency Selector",
      "default": true
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "default": "scheme_1",
      "label": "Color scheme"
    }
  ],
  "presets": [
    {
      "name": "topbar"
    }
  ]
}
{% endschema %}
