{% stylesheet %}
{% endstylesheet %}

<div class="topbar-inner" style="background-color: {{ section.settings.bg_color }}"></div>

{% schema %}
{
  "name": "Topbar",
  "tag": "header",
  "class": "topbar",
  "enabled_on": {
    "groups": ["header"]
  },
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color"
    }
  ],
  "presets": [
    {
      "name": "topbar"
    }
  ]
}
{% endschema %}
