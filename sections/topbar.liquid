{% stylesheet %}
  .topbar-inner {
    padding: 8px 0;
  }
{% endstylesheet %}

<style>
  .topbar {
      background-color: {{section.settings.bg_color}}
  }
</style>

<div class="topbar-inner"></div>

{% schema %}
{
  "name": "Topbar",
  "class": "topbar",
  "enabled_on": {
    "groups": ["header"]
  },
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color"
    },
    {
      "type": "text",
      "id": "left_text",
      "label": "Left Text"
    }
  ],
  "presets": [
    {
      "name": "topbar"
    }
  ]
}
{% endschema %}
