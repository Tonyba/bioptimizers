<div class="img">
    {{ section.settings.image | image_url: width: 200 | image_tag: alt: section.settings.section_image.alt }}
</div>
<div class="txt">

</div>

{% stylesheet %}
    .img{
        width: 700px;
    }
{% endstylesheet %}

{% schema %}
{
  "name": "Shop product",
  "settings": [
    {
        "type": "product",
        "id": "product",
        "label": "Choose product"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Choose image"
    },
    {
      "type": "color",
      "id": "color",
      "label": "BSackground color"
    }
  ],
  "presets": [
    {
      "name": "Shop Product"
    }
  ]
}
{% endschema %}