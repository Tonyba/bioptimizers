{{ 'embla-styles.css' | asset_url | stylesheet_tag }}

{% stylesheet %}
  .home-hero .embla__item:after {
    content: '';
    width: 100%;
    height: 100%;
    position: absolute;
    left: 0;
    top: 0;
    background-image: linear-gradient(90deg, rgba(255, 255, 255, 0) 34%, rgba(255, 255, 255, 1) 55%);
  }

  .home-hero .inner-content {
    max-width: 559px;
    padding-right: 20px;
  }

  .home-hero .col-img {
    width: 55%;
  }

  .home-hero img {
    width: 100%;
    height: 600px;
  }

  .home-hero .subheading {
    color: #018476;
    display: inline-block;
    text-transform: uppercase;
    letter-spacing: 12%;
    font-weight: bold;
    margin-bottom: 13px;
    border-bottom: 2px solid;
    padding-bottom: 9px;
    line-height: 1;
  }

  .home-hero .content {
    font-size: 18px;
  }

  .home-hero .heading {
    font-size: 52px;
    font-weight: bold;
    line-height: 110.00000000000001%;
    margin-bottom: 20px;
  }

  .home-hero .col-text {
    z-index: 1;
  }

  .home-hero .button-secondary {
    border: 2px solid;
  }

  .home-hero .section {
    position: unset;
  }

  .home-hero .embla__dots {
    position: absolute;
    right: 20%;
    bottom: 60px;
    max-width: 500px;
    width: 100%;
  }

  .home-hero .embla__dots button {
    flex: 1;
    background-color: var(--border-color);
    border: 0;
    border-radius: 3px;
  }

  .home-hero .embla__dots .embla__dot--selected {
    background-color: var(--color-primary-button-background);
  }
{% endstylesheet %}

<div class="embla cols-1 color-scheme-1 absolute-arrows ">
  <div class="embla__viewport">
    <div class="embla__container relative">
      {% for item in section.blocks %}
        <div class="flex embla__item  no-template-areas relative">
          <div class="col col-img">
            {% if item.settings.image != blank %}
              {{
                item.settings.image
                | image_url: width: item.settings.image.width, height: item.settings.image.height
                | image_tag: class: 'img-cover'
              }}
            {% endif %}
          </div>
          <div class="col col-text flex items-center relative">
            <div class="inner-content">
              <div class="subheading">{{ item.settings.subheading }}</div>
              <div class="heading">{{ item.settings.heading }}</div>
              <div class="content">
                {{ item.settings.text }}
              </div>

              {% if item.settings.button_text_1 != blank or item.settings.button_text_2 != blank %}
                <div class="flex">
                  {% if item.settings.button_text_1 != blank %}
                    <form
                      method="post"
                      action="/cart/add"
                      id="QuickAdd-ProductForm-7339385782357-AY1Z2SGVvc0ZldWZVO__product_card_gallery_ETLP7a"
                      accept-charset="UTF-8"
                      class="shopify-product-form"
                      enctype="multipart/form-data"
                      novalidate="novalidate"
                      data-type="add-to-cart-form"
                    >
                      <input type="hidden" name="form_type" value="product"><input type="hidden" name="utf8" value="✓"
                      ><input type="hidden" name="id" ref="variantId" value="42244671733845">
                      <input type="hidden" name="quantity" value="1">

                      <add-to-cart-component
                        ref="addToCartButtonContainer"
                        data-product-variant-media=""
                        data-add-to-cart-animation="true"
                      >
                        <button
                          type="submit"
                          name="add"
                          ref="addToCartButton"
                          on:click="/handleClick"
                          class="button button quick-add__button quick-add__button--add add-to-cart-button"
                        >
                          <span class="add-to-cart-text">
                            <span aria-hidden="true" class="svg-wrapper add-to-cart-icon">
                              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="none">
                                <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="var(--icon-stroke-width)" d="M16.608 9.421V6.906H3.392v8.016c0 .567.224 1.112.624 1.513.4.402.941.627 1.506.627H8.63M8.818 3h2.333c.618 0 1.212.247 1.649.686a2.35 2.35 0 0 1 .683 1.658v1.562H6.486V5.344c0-.622.246-1.218.683-1.658A2.33 2.33 0 0 1 8.82 3"></path><path stroke="currentColor" stroke-linecap="round" stroke-width="var(--icon-stroke-width)" d="M14.608 12.563v5m2.5-2.5h-5"></path>
                              </svg>
                            </span>

                            <span class="add-to-cart-text__content is-visually-hidden-mobile">
                              <span>
                                <span>Add</span>
                              </span>
                            </span>
                          </span>

                          <span class="add-to-cart__added">
                            <span class="svg-wrapper add-to-cart__added-icon">
                              <svg
                                aria-hidden="true"
                                class="checkmark-burst"
                                viewBox="0 0 24 24"
                                fill="none"
                                xmlns="http://www.w3.org/2000/svg"
                              >
                                <g class="check">
                                  <circle class="ring" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></circle>
                                  <path class="tick" d="M9 12.75L11.25 15L15 9.75" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
                                </g>
                                <g class="burst">
                                  <g style="--index: 0;">
                                    <line class="line" stroke-linecap="round" pathLength="1" x1="12" y1="8.5" x2="12" y2="15.5" stroke="currentColor"></line>
                                  </g>
                                  <g style="--index: 1;">
                                    <line class="line" stroke-linecap="round" pathLength="1" x1="12" y1="8.5" x2="12" y2="15.5" stroke="currentColor"></line>
                                  </g>
                                  <g style="--index: 2;">
                                    <line class="line" stroke-linecap="round" pathLength="1" x1="12" y1="8.5" x2="12" y2="15.5" stroke="currentColor"></line>
                                  </g>
                                  <g style="--index: 3;">
                                    <line class="line" stroke-linecap="round" pathLength="1" x1="12" y1="8.5" x2="12" y2="15.5" stroke="currentColor"></line>
                                  </g>
                                  <g style="--index: 4;">
                                    <line class="line" stroke-linecap="round" pathLength="1" x1="12" y1="8.5" x2="12" y2="15.5" stroke="currentColor"></line>
                                  </g>
                                  <g style="--index: 5;">
                                    <line class="line" stroke-linecap="round" pathLength="1" x1="12" y1="8.5" x2="12" y2="15.5" stroke="currentColor"></line>
                                  </g>
                                  <g style="--index: 6;">
                                    <line class="line" stroke-linecap="round" pathLength="1" x1="12" y1="8.5" x2="12" y2="15.5" stroke="currentColor"></line>
                                  </g>
                                  <g style="--index: 7;">
                                    <line class="line" stroke-linecap="round" pathLength="1" x1="12" y1="8.5" x2="12" y2="15.5" stroke="currentColor"></line>
                                  </g>
                                </g>
                              </svg>
                            </span>
                          </span>
                        </button>
                      </add-to-cart-component>

                      <button
                        class="button quick-add__button quick-add__button--choose add-to-cart-button"
                        type="button"
                        name="add"
                        on:click="quick-add-component/handleClick"
                      >
                        <span class="add-to-cart-text">
                          <span aria-hidden="true" class="svg-wrapper add-to-cart-icon">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="none">
                              <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="var(--icon-stroke-width)" d="M16.608 9.421V6.906H3.392v8.016c0 .567.224 1.112.624 1.513.4.402.941.627 1.506.627H8.63M8.818 3h2.333c.618 0 1.212.247 1.649.686a2.35 2.35 0 0 1 .683 1.658v1.562H6.486V5.344c0-.622.246-1.218.683-1.658A2.33 2.33 0 0 1 8.82 3"></path><path stroke="currentColor" stroke-linecap="round" stroke-width="var(--icon-stroke-width)" d="M14.608 12.563v5m2.5-2.5h-5"></path>
                            </svg>
                          </span>
                          <span class="add-to-cart-text__content is-visually-hidden-mobile">
                            <span>
                              <span> Choose </span>
                            </span>
                          </span>
                        </span></button
                      ><input type="hidden" name="product-id" value="7339385782357"
                      ><input type="hidden" name="section-id" value="template--17474227208277__product_list_ipJ3z4">
                    </form>
                    <a class="button flex items-center" href="{{ item.settings.button_link_1 }}">
                      <span class="icon">{% render 'icon', icon: 'bag' %}</span>
                      {{ item.settings.button_text_1 }}
                    </a>
                  {% endif %}

                  {% if item.settings.button_text_2 != blank %}
                    <a class="button button-secondary" href="{{ item.settings.button_link_2 }}">
                      {{ item.settings.button_text_2 }}
                    </a>
                  {% endif %}
                </div>
              {% endif %}
            </div>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
  <div class="embla__controls">
    <button class="embla__button embla__button--prev" type="button">
      {% render 'icon', icon: 'chevron-left' %}
    </button>

    <button class="embla__button embla__button--next" type="button">
      {% render 'icon', icon: 'chevron-right' %}
    </button>

    <div class="embla__dots flex"></div>
  </div>
</div>

<script src="{{ 'embla-carousel.umd.js' | asset_url }}" defer></script>
<script src="{{ 'mount-embla.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Home Hero",
  "class": "home-hero",
  "settings": [],
  "blocks": [
    {
      "type": "carousel-item",
      "name": "carousel-item",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "subheading",
          "label": "Subheading"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Text"
        },
        {
          "type": "header",
          "content": "Buttons"
        },
        {
          "type": "text",
          "id": "button_text_1",
          "label": "1st Button Text"
        },
        {
          "type": "url",
          "id": "button_link_1",
          "label": "1st Button link"
        },
        {
          "type": "text",
          "id": "button_text_2",
          "label": "2st Button Text"
        },
        {
          "type": "url",
          "id": "button_link_2",
          "label": "2st Button link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Home Hero"
    }
  ]
}
{% endschema %}
