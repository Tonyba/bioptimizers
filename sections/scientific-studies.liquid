{% liquid
    assign scientificstudies = product.metafields.custom.scientific_studies.value
%}

<div class="section">
    
    {% for item in scientificstudies %}
        <div class="flex">
            {% if forloop.index < 10 %}
                0{{ forloop.index }}
            {% else %}
                {{ forloop.index }}
            {% endif %}
            <div class="item">
                {{ item }}
            </div>
        </div>
    {% endfor %}
</div>

{% schema %}
{
  "name": "Scientific Studies",
  "presets": [
    {
        "name": "Scientific Studies"
    }
  ]
}
{% endschema %}