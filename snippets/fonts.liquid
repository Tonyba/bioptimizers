{% # theme-check-disable %}
{%- unless settings.type_body_font.system? -%}
  <link
    rel="preload"
    as="font"
    href="{{ settings.type_body_font | font_url }}"
    type="font/woff2"
    crossorigin
    fetchpriority="low"
  >
{%- endunless -%}
{%- unless settings.type_subheading_font.system? -%}
  <link
    rel="preload"
    as="font"
    href="{{ settings.type_subheading_font | font_url }}"
    type="font/woff2"
    crossorigin
    fetchpriority="low"
  >
{%- endunless -%}
{%- unless settings.type_heading_font.system? -%}
  <link
    rel="preload"
    as="font"
    href="{{ settings.type_heading_font | font_url }}"
    type="font/woff2"
    crossorigin
    fetchpriority="low"
  >
{%- endunless -%}
{%- unless settings.type_accent_font.system? -%}
  <link
    rel="preload"
    as="font"
    href="{{ settings.type_accent_font | font_url }}"
    type="font/woff2"
    crossorigin
    fetchpriority="low"
  >
{%- endunless -%}
<link
  rel="preload"
  as="font"
  href="{{ 'figtree-v9-latin-500.woff2' | asset_url }}"
  type="font/woff2"
  crossorigin
  fetchpriority="low"
>

<style>
  @font-face {
    font-family: Figtree;
    font-weight: 500;
    font-style: normal;
    font-display: swap;
    src: url({{ 'figtree-v9-latin-500.woff2' | asset_url }}) format("woff2");
  }
</style>

{% # theme-check-enable %}
