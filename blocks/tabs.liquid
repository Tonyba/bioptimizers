{% assign benefits__header = product.metafields.custom.benefits_header.value %}
{% assign benefits__content = product.metafields.custom.benefits_content.value %}

<div class="tab">
  <button class="tablinks" onclick="openTab(event, 'a')">About {{product.title}}</button>
  <span class="vertical_divider"></span>
  <button class="tablinks" onclick="openTab(event, 'b')">Benefits</button>
  <span class="vertical_divider"></span>
  <button class="tablinks" onclick="openTab(event, 'd')">How to Take </button>
  <span class="vertical_divider"></span>
  <button class="tablinks" onclick="openTab(event, 'e')">Faqs</button>
  <span class="vertical_divider"></span>
  <button class="tablinks" onclick="openTab(event, 'f')">Loading Program</button>
</div>

<!-- Tab content -->
<div id="a" class="tabcontent">
  <h3>About</h3>
  <p>{{product.description}}</p>
</div>

<div id="b" class="tabcontent">
    <div class="image-box">
      <img src="https://images.unsplash.com/photo-1599058917765-a780eda07a3e" alt="Relaxing woman" width="100px" height="100px">
    </div>
    <div class="benefit">
        <h3>{{product.title}} Benefits</h3>
        {% for item in benefits__header %}
            <div class="benefit-header flex">
                <div class="index-number">
                    {% if forloop.index < 10 %}
                            0{{ forloop.index }}.
                        {% else %}
                            {{ forloop.index }}.
                        {% endif %}
                </div>
                <div class="benefit-title">{{item}}</div>
            </div>
            <p>
            Magnesium is extremely important for heart health and blood vessel health.
            Magnesium deficiency seems to worsen inflammation, blood vessel constriction,
            blood clotting, and stress responses that trigger heart conditions.
            </p>
            
        {% endfor %}
        
    </div>
    
    
</div>

<div id="c" class="tabcontent">
  <h3>Tokyo</h3>
  <p>Tokyo is the capital of Japan.</p>
</div>
<script>
function openTab(evt, tabId) { // Renamed 'tab' to 'tabId' for clarity
        // Declare all variables
        var i, tabcontent, tablinks;

        // Get all elements with class="tabcontent" and hide them
        tabcontent = document.getElementsByClassName("tabcontent");
        for (i = 0; i < tabcontent.length; i++) {
            tabcontent[i].style.display = "none";
        }

        // Get all elements with class="tablinks" and remove the class "active"
        tablinks = document.getElementsByClassName("tablinks");
        for (i = 0; i < tablinks.length; i++) {
            tablinks[i].className = tablinks[i].className.replace(" active", "");
        }

        // Show the current tab, and add an "active" class to the button that opened the tab
        document.getElementById(tabId).style.display = "block";
        // Check if evt exists, because openTab will be called without an event on load
        if (evt) {
            evt.currentTarget.className += " active";
        } else {
            // If no event, find the button by its data-tab (or in this case, by its associated tabId in the HTML)
            // This is a slightly more robust way for the initial load if the button isn't directly passed
            document.querySelector(`.tablinks[onclick*='${tabId}']`).className += " active";
        }
    }

    // --- Call openTab for the first tab on page load ---
    document.addEventListener('DOMContentLoaded', function() {
        // Call openTab with null for the event (since it's not a click event) and 'a' for the tab ID
        openTab(null, 'a');

        // You might also want to simulate a click on the first button
        // if your 'active' class has specific CSS that relies on the button being clicked.
        // let firstButton = document.querySelector('.tablinks.active');
        // if (firstButton) {
        //     firstButton.click();
        // } else {
        //     // Fallback if 'active' class isn't on the first button in HTML
        //     document.querySelector('.tablinks').click();
        // }
    });
</script>

{% stylesheet %}
.image-box img {
    width: 500px;
    height: 500px;
    border-radius: 12px;
    object-fit: cover;
    float: right;
    margin-left: 80px;
    margin-bottom: 30px;
  }
.tab {
  display: flex;
  align-items: space-between;
  justify-content: space-between;
  background: #1f1b1b;
  padding: 35px 30px;
  border-radius: 6px 6px 0 0;
  gap: 20px;
}
.tabcontent{
    background-color: #F9F9F9;
    padding: 60px 58px;
}

/* Buttons */
.tab button {
    font-weight: 600;
    font-size: 21px !important;
    background: none;
    border: none;
    color: #aaa;
    font-size: 14px;
    cursor: pointer;
    padding: 10px 16px;
    position: relative;
    transition: 0.3s;
}

.tab button::before{
    content: "";
    position: absolute;
    bottom: -6px;
    left: 0;
    width: 100%;
    height: 2px;
    background: #888888;
}

/* Vertical divider */
.vertical_divider {
    content: "";
    border-right: 1px solid #A6A6A6;
    height: auto;
}

/* Hover */
.tab button:hover {
    color: #fff;
}

/* Active tab */
.tab button.active {
    color: #fff;
}

/* Orange underline */
.tab button.active::before {
    content: "";
    position: absolute;
    bottom: -6px;
    left: 0;
    width: 100%;
    height: 2px;
    background: #F58220;
}

{% endstylesheet %}

{% schema %}
{
  "name": "Tabs",
  "class": "w-100",
  "settings": [
    
  ],
  "presets": [
    {
      "name": "Static Tabs"
    }
  ]
}
{% endschema %}