<div class="tab">
  <button class="tablinks" onclick="openTab(event, 'a')">About Magnesium Breakthrough</button>
  <button class="tablinks" onclick="openTab(event, 'b')">Benefits</button>
  <button class="tablinks" onclick="openTab(event, 'd')">How to Take </button>
  <button class="tablinks" onclick="openTab(event, 'e')">Faqs</button>
  <button class="tablinks" onclick="openTab(event, 'f')">Loading Program</button>
</div>

<!-- Tab content -->
<div id="a" class="tabcontent">
  <h3>London</h3>
  <p>London is the capital city of England.</p>
</div>

<div id="b" class="tabcontent">
    <div class="benefit">
        <div class="benefit-header">
          <div class="number">01.</div>
          <div class="benefit-title">Promotes Heart Health</div>
        </div>
        <p>
          Magnesium is extremely important for heart health and blood vessel health.
          Magnesium deficiency seems to worsen inflammation, blood vessel constriction,
          blood clotting, and stress responses that trigger heart conditions.
        </p>
    </div>
    <div class="image-box">
      <img src="https://images.unsplash.com/photo-1599058917765-a780eda07a3e" alt="Relaxing woman" width="100px" height="100px">
    </div>
</div>

<div id="c" class="tabcontent">
  <h3>Tokyo</h3>
  <p>Tokyo is the capital of Japan.</p>
</div>
<script>
    function openTab(evt, tab) {
  // Declare all variables
  var i, tabcontent, tablinks;

  // Get all elements with class="tabcontent" and hide them
  tabcontent = document.getElementsByClassName("tabcontent");
  for (i = 0; i < tabcontent.length; i++) {
    tabcontent[i].style.display = "none";
  }

  // Get all elements with class="tablinks" and remove the class "active"
  tablinks = document.getElementsByClassName("tablinks");
  for (i = 0; i < tablinks.length; i++) {
    tablinks[i].className = tablinks[i].className.replace(" active", "");
  }

  // Show the current tab, and add an "active" class to the button that opened the tab
  document.getElementById(tab).style.display = "block";
  evt.currentTarget.className += " active";
}
</script>

{% stylesheet %}
.benefit {
    padding: 20px 0;
    border-bottom: 1px solid #ddd;
  }

  .benefit:last-child {
    border-bottom: none;
  }

  .benefit-header {
    display: flex;
    gap: 15px;
    align-items: flex-start;
    margin-bottom: 10px;
  }

  .number {
    color: #0f9d8a;
    font-weight: bold;
    font-size: 14px;
    min-width: 30px;
  }

  .benefit-title {
    font-weight: 700;
    font-size: 14px;
    text-transform: uppercase;
  }

  .benefit p {
    font-size: 13px;
    line-height: 1.6;
    color: #555;
    margin: 0;
  }
.image-box img {
    width: 100%;
    border-radius: 12px;
    object-fit: cover;
  }
.tab {
  display: flex;
  align-items: center;
  background: #1f1b1b;
  padding: 35px 30px;
  border-radius: 6px 6px 0 0;
  gap: 20px;
}
.tabcontent{
    background-color: #F9F9F9;
    padding: 60px 58px;
}

/* Buttons */
.tab button {
    font-weight: 600;
    font-size: 21px !important;
    background: none;
    border: none;
    color: #aaa;
    font-size: 14px;
    cursor: pointer;
    padding: 10px 16px;
    position: relative;
    transition: 0.3s;
}

.tab button::before{
    content: "";
    position: absolute;
    bottom: -6px;
    left: 0;
    width: 100%;
    height: 2px;
    background: #888888;
}

/* Vertical divider */
.tab button:not(:last-child)::after {
    content: "";
    position: absolute;
    right: -10px;
    top: 50%;
    transform: translateY(-50%);
    width: 1px;
    height: 20px;
    background: #A6A6A6;
}

/* Hover */
.tab button:hover {
    color: #fff;
}

/* Active tab */
.tab button.active {
    color: #fff;
}

/* Orange underline */
.tab button.active::before {
    content: "";
    position: absolute;
    bottom: -6px;
    left: 0;
    width: 100%;
    height: 2px;
    background: #F58220;
}

{% endstylesheet %}

