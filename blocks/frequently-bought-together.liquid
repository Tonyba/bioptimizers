
<div class="flex">
    {% for product in block.settings.product_list %}
    {% assign org = product.compare_at_price %}
    <div id="container" class="fbt-item width h-100 ">
        {% assign img = product.metafields.custom.loop_image.value %}
        {% if img %}
            <div class="image-card">
                
                <input class="check-position" type="checkbox"
                   id="fbt-variant-{{ product.id }}"
                   value="{{ product.id }}"
                   data-price="{{ product.price | money_without_currency | replace: ',', '' }}"
                   data-after-price="{{ product.compare_at_price }}"
                   checked onchange="updateFBTPrice()">
                {{ img | image_url: width: 300 | image_tag: loading: 'lazy', alt: product.title }}
            </div>
        {% elsif product.featured_image %}
            <div lass="image-card">
                {{ product.featured_image | image_url: width: 300 | image_tag: loading: 'lazy', alt: product.title }}
                <input class="check-position" type="checkbox" name="product_id" value="{{ product.id }}">
            </div>
        {% endif %}

        <p id="size"><strong>{{ product.title }}</strong></p>
        <p id="cyan"><strong>{{ product.price | money }}{{ org }}</strong></p>
        
    </div>

    <div id="myBlueDiv">{% render 'icon-plus' %}</div>
    {% endfor %}
    <p>Total: <span id="totalAfterPrice"></span>-<span id="totalPrice"></span></p>
</div>

<script>
function updateFBTPrice() {
  let total = 0;
  let afterTotal = 0;

  const checkedBoxes = document.querySelectorAll(".check-position:checked");

  checkedBoxes.forEach(cb => {
    total += parseFloat(cb.dataset.price) || 0;
    afterTotal += parseFloat(cb.dataset.afterPrice) || 0;
  });

  document.getElementById("totalPrice").textContent = total.toFixed(2);
  document.getElementById("totalAfterPrice").textContent = afterTotal.toFixed(2);
}
</script>

{% stylesheet %}
#myBlueDiv {
 position: relative;
 top: 125px;
}
#myBlueDiv:last-child{
    display: none;
}
.image-card input:checked, .image-card input:hover {
    background-color: #018476;
    border: 2px solid transparent;
}
.check-position{
    position: absolute;
    top: 10px;     
    right: 10px;   
    width: 25px;
    height: 25px;
    z-index: 99;
    border: 2px solid black;
}
    #size{
        font-size: 18px;
    }
    #cyan{
        color: #018476;
        font-size: 21px;
    }
    .width{
        width: 230px;
    }
    .image-card{
        position: relative; /* important */
  display: inline-block;
        border: 2px solid #D9D9D9;
        border-radius: 10px;
        padding: 20px;
    }
{% endstylesheet %}

{% schema %}
{
  "name": "Frequently bought",
  "settings": [
    {
      "type": "product_list",
      "id": "product_list",
      "label": "Products"
    }
  ],
  "presets": [
    {
      "name": "Frequently bought together"
    }
  ]
}
{% endschema %}
