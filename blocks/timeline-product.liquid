{% liquid
  assign timelineheader = product.metafields.custom.timeline_items.value
  assign timelinecontent = product.metafields.custom.timeline_items_content.value
%}

<div class="">
    
{% comment %} <div class="left">
    {{ section.settings.image | image_url: width: 600 | image_tag: loading: 'lazy', alt: section.settings.image.alt }}
</div> {% endcomment %}
   
    <div class="right">  
        <div class="timeline">
            {% for item in timelineheader %}
                {% assign i = forloop.index0 %}
                {% assign otheritem = timelinecontent[i] %}
                <div class="timeline-item">
                <div class="timeline-number">
                    {{ forloop.index | prepend: '0' }}
                </div>
                <div class="timeline-content">
                    <h3>{{ item }}</h3>
                    <p>{{ otheritem }}</p>
                </div>
                </div>
            {% endfor %}
        </div>
    </div>      
</div>

{% schema  %} 
    {
        "name": "Timeline Section",
        "class": "w-100",
        "settings": [
            {
                "type": "text",
                "id": "custom_css",
                "label": "Custom CSS classes"
            },
            {
                "type": "image_picker",
                "id": "image",
                "label": "Left Image"
            }
        ],
        "presets": [
    {
        "name": "Timeline product block"
    }
  ]
    }
{% endschema %}