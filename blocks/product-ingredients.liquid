{% stylesheet %}
.comparison-table-container {
    width: 100%;
    max-width: 1200px; /* Adjust as needed */
    overflow-x: auto; /* Enable horizontal scrolling on small screens */
    background-color: #fff;
    border-radius: 8px;
    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.05);
}

/* Table Styling */
.comparison-table {
    width: 100%;
    border-collapse: collapse; /* Remove space between cells */
    min-width: 900px; /* Ensure table doesn't shrink too much */
}

/* Table Headers */
.comparison-table th,
.comparison-table td {
    padding: 15px 10px;
    text-align: center;
    border: 1px solid #e0e0e0;
    vertical-align: middle;
}

.comparison-table thead th {
    background-color: #f2f2f2;
    font-weight: bold;
    color: #333;
    white-space: nowrap; /* Prevent product names from wrapping */
}

/* Highlighted Column (Your product) */
.highlight {
    background-color: #FFF2E6; /* Light orange background */
}

/* Top-left corner cell (empty) */
.table-corner-cell {
    background-color: #fff; /* White background */
    border-right: none;
    border-bottom: none;
}

/* Product Column Headers */
.product-column {
    width: 10%; /* Distribute width among product columns */
    min-width: 100px; /* Minimum width for product columns */
}

.product-header-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
}

.product-image-wrapper {
    width: 80px; /* Size for product image */
    height: 100px;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #fff; /* White background for image */
    border-radius: 5px;
    padding: 5px;
    box-shadow: 0 2px 5px rgba(0,0,0,0.1);
}

.product-image-wrapper img {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
}

.product-name {
    font-size: 0.9em;
    font-weight: bold;
    color: #333;
}

/* Feature Cells (leftmost column) */
.feature-cell {
    text-align: left;
    font-weight: bold;
    color: #555;
    background-color: #f9f9f9;
    padding-left: 20px;
    white-space: nowrap;
}
.feature-cell.highlight {
    background-color: #FFE6CC; /* Slightly darker orange for highlighted feature cell */
}

/* Check/Times Cells */
.check-cell {
    font-size: 1.5em; /* Size of the check/x icons */
}

.check-icon {
    color: #018476; /* Green for checkmark */
    font-weight: bold;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background-color: #E6F3F2; /* Light green background */
}

.times-icon {
    color: #c9302c; /* Red for X mark */
    font-weight: bold;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background-color: #F8E6E6; /* Light red background */
}

/* Highlight specific column cells in body */
.comparison-table tbody td.highlight {
    background-color: #FFE6CC;
}
.comparison-table tbody td.highlight .check-icon {
    background-color: #018476; /* Darker green background */
    color: #fff; /* White checkmark */
}
.comparison-table tbody td.highlight .times-icon {
    background-color: #c9302c; /* Darker red background */
    color: #fff; /* White X mark */
}

/* General table row styling (alternating background if desired, or just hover) */
.comparison-table tbody tr:nth-child(even) {
    /* background-color: #fcfcfc; */
}
.comparison-table tbody tr:hover {
    background-color: #f5f5f5;
}

/* Adjustments for first row in tbody (if it has special styling needs) */
.comparison-table tbody tr:first-child .feature-cell {
    border-top: 1px solid #e0e0e0; /* Ensure top border if header doesn't connect well */
}
{% endstylesheet %}

