{% stylesheet %}
  .table-container {
    max-width: 1100px;
    margin: 40px auto;
    overflow-x: auto;
  }

  table {
    min-width: 900px;
    border-collapse: collapse;
    background: white;
  }

  th, td {
    text-align: center;
    padding: 14px;
    vertical-align: bottom;
    font-size: 14px;
  }

  th {
    font-weight: 600;
   
  }
  th:not(:first-child), td:not(:first-child){
    border-right: 1px solid #DFDFDF;
  }

  /* First column (labels) */
  td.label {
    text-align: left;
    font-weight: 500;
  }
  tbody tr:nth-child(odd) {
    background-color: #f2f2f2;
    }

  /* Highlighted product column */
  .highlight {
    background: #f5a623;
    color: black;
    font-weight: 600;
    border-top: 1px solid white;
  }

  .highlight-header {
    background: #f5a623;
    color: black;
    border-radius: 20px 20px 0 0;
  }

  /* Icons */
  .check {
    display: inline-block;
    width: 18px;
    height: 18px;
    background: #0f9d8a;
    color: white;
    line-height: 18px;
    border-radius: 3px;
    font-size: 12px;
  }

  .cross {
    display: inline-block;
    width: 18px;
    height: 18px;
    background: #e0e0e0;
    color: #666;
    line-height: 18px;
    border-radius: 3px;
    font-size: 12px;
  }
 .highlight-header img {
    height: 200px;
    margin-bottom: 6px;
    object-fit: contain;
 }

  .empty-product{
    height: 150px;
    margin-bottom: 6px;
  }

  .product-name {
    font-size: 13px;
    margin-top: 5px;
  }
  
{% endstylesheet %}

