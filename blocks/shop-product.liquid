{% if section.settings.position == "row" %}
    {% assign product_position = "p-left" %}
    {% assign buttons_position = "" %}
    {% assign _position = "main_right" %}
{% else %}
    {% assign product_position = "p-left1" %}
    {% assign buttons_position = "self-end" %}
    {% assign _position = "main_left" %}
{% endif %}

<div class="main {{ _position }}" id="shop-product-{{ block.id }}">
    <div class="imgg">
        {{ block.settings.image | image_url: width: 2000 | image_tag: alt: section.settings.section_image.alt , loading: "lazy"}}
        <div class="color-gray"></div>
    </div>
    
    <div class="txt">
        <div class="prod-content" style="background-color: {{ block.settings.color }};">{% content_for 'blocks' %}</div>
        <div class="color-gray">
            {% comment %} {% assign product_block_id = block.id | default: '' %}
            {% assign qa_form_id = 'QuickAdd-ProductForm-' | append: section.settings.product.id | append: '-' | append: product_block_id %} {% endcomment %}

            <div class="flex {{ buttons_position }} w70" >
                {% assign variant = section.settings.product.selected_or_first_available_variant %}

                <button
                class="button flex items-center"
                data-variant-id="{{ variant.id }}"
                onclick="shopNowAddToCart(this)">
                <span class="icon">{% render 'icon', icon: 'bag' %}</span>
                <span class="btn-text">Shop Now</span>
                </button>

                <a class="button button-secondary flex items-center" href="{{ block.settings.product.url }}">
                    <span class="icon-second-btn">{% render 'icon', icon: 'chevron-right', width: 17 %}</span>
                    View Product
                </a>
            </div>
        </div>
    </div>
    <div class="product-img {{ product_position }}" style="  ">
        {{ block.settings.product.metafields.custom.loop_image | image_url: width: 2000 | image_tag: alt: 'product bottle'}}
    </div>
</div>

<script>
async function shopNowAddToCart(btn) {
  const variantId = btn.dataset.variantId;
  if (!variantId) return;

  const label = btn.querySelector('.btn-text');
  btn.disabled = true;
  label.textContent = 'Adding...';

  try {
    const res = await fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ items: [{ id: variantId, quantity: 1 }] })
    });

    if (!res.ok) throw new Error('Failed');

    label.textContent = 'Added!';

    // Fire all common theme cart update events
    document.dispatchEvent(new CustomEvent('cart:refresh', { bubbles: true }));
    document.dispatchEvent(new CustomEvent('cart:updated', { bubbles: true }));
    window.dispatchEvent(new CustomEvent('cart:refresh', { bubbles: true }));

    // Trigger theme cart drawer/notification if available
    const cartDrawer = document.querySelector('cart-drawer');
    const cartNotification = document.querySelector('cart-notification');

    if (cartDrawer?.open) {
      cartDrawer.open(btn);
    } else if (cartNotification?.renderContents) {
      cartNotification.renderContents();
    }

    // Update cart count in header
    const cartRes = await fetch('/cart.js');
    const cart = await cartRes.json();
    document.querySelectorAll('[data-cart-count], .cart-count, cart-count, .header__cart-count, [data-item-count]').forEach(el => {
      el.textContent = cart.item_count;
    });

  } catch(e) {
    label.textContent = 'Error';
  } finally {
    setTimeout(() => {
      btn.disabled = false;
      label.textContent = 'Shop Now';
    }, 2000);
  }
}
</script>
{% stylesheet %}
    @media (max-width: 768px){   
    .main_right{
            flex-direction: column !important;
        }
        .main_left{
            flex-direction: column !important;
        }
        .prod-content, .color-gray {
        padding:  20px 20px !important;
    }
    .imgg, .txt{
        width: 100% !important;
    }
    .w70, .w70 .button{
        width: 100% !important;
    }
    .p-left, .p-left1{
        left: 56% !important;
    }
    }
    .w70{
        width: 70%;
    }
    .main_right{
        flex-direction: row;
    }
    .main_left{
        flex-direction: row-reverse;
    }
    .main{
        display: flex;
        /* flex-direction: row-reverse; */
        /* reverse row */
        width: 100%;
        position: relative;
    }
    .imgg{
        width: 35%;
    }
    .imgg img{
        height: 400px;
        object-fit: cover;
    }
    .color-gray{
        background-color: #F9F9F9;
        width: 100%;
        min-height: 100px;
        display: flex;
        flex-direction: column;
        justify-content: center;
    }
    .product_image{
        width: 370px;
        position: absolute;
        left: 475px;
        top: 435px;
    }
    .prod-content, .color-gray {
        padding:  0 160px;
    }
    .prod-content{
        
        height: 400px;
        
        display: flex;
        flex-direction: column;
        justify-content: center;
        gap: 15px;
    }
    .txt{
        width: 65%;
    }
    .product-img {
        position: absolute;
        /* left: 35%; */
        top: 80px;
        transform: translateX(-50%);
        width: 370px;
    }
.p-left{
    left: 35%;
}
.p-left1{
    left: 68%;
}

  .product-img img {
    width: 100%;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Shop product",
  "blocks": [
    {
        "type": "@theme"
    }
  ],
  "settings": [
    {
        "type": "product",
        "id": "product",
        "label": "Choose product"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Choose image"
    },
    {
      "type": "color",
      "id": "color",
      "label": "BSackground color"
    },
    {
        "type": "radio",
        "id": "position",
        "label": "Position",
        "options": [
            {
            "value": "row",
            "label": "Left"
            },
            {
            "value": "row-reverse",
            "label": "Right"
            }
        ],
        "default": "row"
    }
  ],
  "presets": [
    {
      "name": "Shop Product block"
    }
  ]
}
{% endschema %}