      "default": "#f9f9f9"
    },
    {
      "type": "color",
      "id": "button_hover_text_color",
      "label": "Hover text",
      "default": "#07180f"
    },
    {
      "type": "color",
      "id": "button_hover_border_color",
      "label": "Hover border",
      "default": "#d9d9d9"
    }
  ],
  "presets": [
    {
      "name": "Product share buttons"
    }
  ]
