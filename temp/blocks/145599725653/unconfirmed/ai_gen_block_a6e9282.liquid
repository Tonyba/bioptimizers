{% doc %}
  @prompt
    create simple buttons to share the product
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-share-buttons-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
  }

  .ai-share-buttons__container-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.button_spacing }}px;
    align-items: center;
    flex-wrap: wrap;
  }

  .ai-share-buttons__label-{{ ai_gen_id }} {
    font-size: {{ block.settings.label_size }}px;
    color: {{ block.settings.label_color }};
    margin-bottom: 8px;
    display: block;
  }

  .ai-share-buttons__button-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: {{ block.settings.button_padding }}px {{ block.settings.button_padding | times: 1.5 }}px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    border: {{ block.settings.button_border_width }}px solid {{ block.settings.button_border_color }};
    border-radius: {{ block.settings.button_border_radius }}px;
    text-decoration: none;
    font-size: {{ block.settings.button_font_size }}px;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .ai-share-buttons__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
    color: {{ block.settings.button_hover_text_color }};
    border-color: {{ block.settings.button_hover_border_color }};
  }

  .ai-share-buttons__icon-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    flex-shrink: 0;
  }

  @media screen and (max-width: 749px) {
    .ai-share-buttons__container-{{ ai_gen_id }} {
      gap: {{ block.settings.button_spacing | times: 0.8 }}px;
    }
  }
{% endstyle %}

<product-share-buttons-{{ ai_gen_id }}
  class="ai-share-buttons-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  {% if block.settings.show_label %}
    <span class="ai-share-buttons__label-{{ ai_gen_id }}">{{ block.settings.label_text }}</span>
  {% endif %}

  <div class="ai-share-buttons__container-{{ ai_gen_id }}">
    {% if block.settings.show_facebook %}
      <a
        href="#"
        class="ai-share-buttons__button-{{ ai_gen_id }} ai-share-facebook-{{ ai_gen_id }}"
        aria-label="Share on Facebook"
        data-share-platform="facebook"
      >
        <svg class="ai-share-buttons__icon-{{ ai_gen_id }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path>
        </svg>
        {% if block.settings.show_button_text %}
          <span>Facebook</span>
        {% endif %}
      </a>
    {% endif %}

    {% if block.settings.show_twitter %}
      <a
        href="#"
        class="ai-share-buttons__button-{{ ai_gen_id }} ai-share-twitter-{{ ai_gen_id }}"
        aria-label="Share on Twitter"
        data-share-platform="twitter"
      >
        <svg class="ai-share-buttons__icon-{{ ai_gen_id }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M23 3a10.9 10.9 0 0 1-3.14 1.53 4.48 4.48 0 0 0-7.86 3v1A10.66 10.66 0 0 1 3 4s-4 9 5 13a11.64 11.64 0 0 1-7 2c9 5 20 0 20-11.5a4.5 4.5 0 0 0-.08-.83A7.72 7.72 0 0 0 23 3z"></path>
        </svg>
        {% if block.settings.show_button_text %}
          <span>Twitter</span>
        {% endif %}
      </a>
    {% endif %}

    {% if block.settings.show_pinterest %}
      <a
        href="#"
        class="ai-share-buttons__button-{{ ai_gen_id }} ai-share-pinterest-{{ ai_gen_id }}"
        aria-label="Share on Pinterest"
        data-share-platform="pinterest"
      >
        <svg class="ai-share-buttons__icon-{{ ai_gen_id }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"></circle>
          <path d="M8 12c0-2.21 1.79-4 4-4 2.76 0 5 2.24 5 5 0 2.21-1.79 4-4 4-.55 0-1.08-.11-1.56-.31L10 20"></path>
        </svg>
        {% if block.settings.show_button_text %}
          <span>Pinterest</span>
        {% endif %}
      </a>
    {% endif %}

    {% if block.settings.show_email %}
      <a
        href="#"
        class="ai-share-buttons__button-{{ ai_gen_id }} ai-share-email-{{ ai_gen_id }}"
        aria-label="Share via Email"
        data-share-platform="email"
      >
        <svg class="ai-share-buttons__icon-{{ ai_gen_id }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
          <polyline points="22,6 12,13 2,6"></polyline>
        </svg>
        {% if block.settings.show_button_text %}
          <span>Email</span>
        {% endif %}
      </a>
    {% endif %}

    {% if block.settings.show_copy_link %}
      <button
        class="ai-share-buttons__button-{{ ai_gen_id }} ai-share-copy-{{ ai_gen_id }}"
        aria-label="Copy link"
        data-share-platform="copy"
      >
        <svg class="ai-share-buttons__icon-{{ ai_gen_id }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path>
          <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path>
        </svg>
        {% if block.settings.show_button_text %}
          <span class="ai-share-copy-text-{{ ai_gen_id }}">Copy link</span>
        {% endif %}
      </button>
    {% endif %}
  </div>
</product-share-buttons-{{ ai_gen_id }}>

<script>
  (function() {
    class ProductShareButtons{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.productUrl = window.location.href;
        this.productTitle = document.title;
        this.productImage = '';
        
        const metaImage = document.querySelector('meta[property="og:image"]');
        if (metaImage) {
          this.productImage = metaImage.getAttribute('content');
        }
      }

      connectedCallback() {
        this.setupEventListeners();
      }

      setupEventListeners() {
        const buttons = this.querySelectorAll('[data-share-platform]');
        
        buttons.forEach((button) => {
          button.addEventListener('click', (e) => {
            e.preventDefault();
            const platform = button.getAttribute('data-share-platform');
            this.share(platform);
          });
        });
      }

      share(platform) {
        const encodedUrl = encodeURIComponent(this.productUrl);
        const encodedTitle = encodeURIComponent(this.productTitle);
        const encodedImage = encodeURIComponent(this.productImage);
        
        let shareUrl = '';

        if (platform === 'facebook') {
          shareUrl = `https://www.facebook.com/sharer/sharer.php?u=${encodedUrl}`;
        } else if (platform === 'twitter') {
          shareUrl = `https://twitter.com/intent/tweet?url=${encodedUrl}&text=${encodedTitle}`;
        } else if (platform === 'pinterest') {
          shareUrl = `https://pinterest.com/pin/create/button/?url=${encodedUrl}&media=${encodedImage}&description=${encodedTitle}`;
        } else if (platform === 'email') {
          shareUrl = `mailto:?subject=${encodedTitle}&body=Check out this product: ${encodedUrl}`;
        } else if (platform === 'copy') {
          this.copyToClipboard();
          return;
        }

        if (shareUrl) {
          window.open(shareUrl, '_blank', 'width=600,height=400');
        }
      }

      copyToClipboard() {
        const copyButton = this.querySelector('.ai-share-copy-{{ ai_gen_id }}');
        const copyText = this.querySelector('.ai-share-copy-text-{{ ai_gen_id }}');
        
        navigator.clipboard.writeText(this.productUrl).then(() => {
          if (copyText) {
            const originalText = copyText.textContent;
            copyText.textContent = 'Copied!';
            
            setTimeout(() => {
              copyText.textContent = originalText;
            }, 2000);
          }
        }).catch((err) => {
          console.error('Failed to copy:', err);
        });
      }
    }

    customElements.define('product-share-buttons-{{ ai_gen_id }}', ProductShareButtons{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Product share buttons",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Label"
    },
    {
      "type": "checkbox",
      "id": "show_label",
      "label": "Show label",
      "default": true
    },
    {
      "type": "text",
      "id": "label_text",
      "label": "Label text",
      "default": "Share this product"
    },
    {
      "type": "range",
      "id": "label_size",
      "label": "Label size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "color",
      "id": "label_color",
      "label": "Label color",
      "default": "#07180f"
    },
    {
      "type": "header",
      "content": "Platforms"
    },
    {
      "type": "checkbox",
      "id": "show_facebook",
      "label": "Show Facebook",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_twitter",
      "label": "Show Twitter",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_pinterest",
      "label": "Show Pinterest",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_email",
      "label": "Show Email",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_copy_link",
      "label": "Show copy link",
      "default": true
    },
    {
      "type": "header",
      "content": "Button style"
    },
    {
      "type": "checkbox",
      "id": "show_button_text",
      "label": "Show button text",
      "default": false
    },
    {
      "type": "range",
      "id": "button_spacing",
      "label": "Button spacing",
      "min": 4,
      "max": 20,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "range",
      "id": "button_padding",
      "label": "Button padding",
      "min": 8,
      "max": 20,
      "step": 2,
      "unit": "px",
      "default": 10
    },
    {
      "type": "range",
      "id": "button_font_size",
      "label": "Font size",
      "min": 12,
      "max": 18,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "range",
      "id": "icon_size",
      "label": "Icon size",
      "min": 16,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "button_border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 3
    },
    {
      "type": "range",
      "id": "button_border_width",
      "label": "Border width",
      "min": 0,
      "max": 4,
      "step": 1,
      "unit": "px",
      "default": 1
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "button_background",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Text",
      "default": "#07180f"
    },
    {
      "type": "color",
      "id": "button_border_color",
      "label": "Border",
      "default": "#d9d9d9"
    },
    {
      "type": "color",
      "id": "button_hover_background",
